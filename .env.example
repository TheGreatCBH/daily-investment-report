# Copy this file to .env and fill in real values. .env is gitignored.

# ── LLM ──────────────────────────────────────────────────────────────────────
# Supports any OpenAI-compatible API: OpenAI, DeepSeek, Groq, Ollama, etc.
#
# LLM_API_KEY   your API key  (DEEPSEEK_API_KEY also accepted as a legacy fallback)
# LLM_BASE_URL  leave empty for OpenAI; set for other providers (see examples below)
# LLM_MODEL     model ID for your chosen provider
#
# Examples:
#   DeepSeek (default):  LLM_BASE_URL=https://api.deepseek.com   LLM_MODEL=deepseek-chat
#   OpenAI:              LLM_BASE_URL=                            LLM_MODEL=gpt-4o
#   Groq:                LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.3-70b-versatile
#   Ollama (local):      LLM_BASE_URL=http://localhost:11434/v1   LLM_MODEL=qwen2.5:7b  LLM_API_KEY=ollama

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── SMTP ─────────────────────────────────────────────────────────────────────
# Use an app password, never your account password.
# Recommended providers:
#   iCloud:  smtp.mail.me.com:587     (Apple ID app password)
#   Gmail:   smtp.gmail.com:587       (app password required)
# Note: Microsoft personal Outlook is OAuth2-only — basic SMTP auth is blocked.
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=your_email@example.com

# ── Optional ──────────────────────────────────────────────────────────────────
# Report language. Default zh-CN; set to en-US for English output.
# REPORT_LOCALE=en-US
