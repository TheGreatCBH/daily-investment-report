# Copy this file to .env and fill in real values. .env is gitignored.

# DeepSeek API key — get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# SMTP credentials for sending the report by email.
# Common providers:
#   Outlook personal:  smtp-mail.outlook.com:587   (app password required if 2FA on)
#   Microsoft 365:     smtp.office365.com:587
#   Gmail:             smtp.gmail.com:587          (app password required)
#   QQ:                smtp.qq.com:587             (authorization code, not real password)
# Use an app password from your account security settings, never your regular password.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=your_email@example.com
